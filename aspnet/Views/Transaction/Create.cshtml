@* Create form for a new Transaction. Uses autocomplete for Player selection. *@
@model aspnet.Models.Transaction
@{
    ViewData["Title"] = "Nova transakcija";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/transakcije">Transakcije</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Nova transakcija</span>
</div>

<h1 class="page-title">Nova transakcija</h1>

<div class="edit-form-wrap">
    <form method="post" action="/transakcije/nova" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label asp-for="Amount" class="form-label">Iznos</label>
            <input asp-for="Amount" class="form-input" type="number" step="0.01" min="0" />
            <span asp-validation-for="Amount" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="Type" class="form-label">Vrsta transakcije</label>
            <select asp-for="Type" class="form-select">
                <option value="">-- Odaberi vrstu --</option>
                @foreach (var val in Enum.GetValues(typeof(aspnet.Models.TransactionType)))
                {
                    <option value="@val">@val</option>
                }
            </select>
            <span asp-validation-for="Type" class="form-validation"></span>
        </div>

        @await Html.PartialAsync("_DatePicker", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "CreatedAt" },
            { "FieldLabel", "Datum i vrijeme" },
            { "Mode", "datetime" },
            { "CurrentValue", Model.CreatedAt }
        })

        @await Html.PartialAsync("_Autocomplete", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "PlayerId" },
            { "FieldLabel", "Igrač" },
            { "EndpointUrl", "/igraci/autocomplete" },
            { "CurrentText", "" },
            { "CurrentId", "" }
        })

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-back" href="/transakcije">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('form').validate({ onfocusout: function (el) { this.element(el); } });
        });
    </script>
}
