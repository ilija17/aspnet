@model List<aspnet.Models.Transaction>
@{
    ViewData["Title"] = "Transakcije";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Transakcije</span>
</div>

<div class="index-action-bar">
    <h1 class="page-title" style="margin:0">Sve transakcije</h1>
    <span class="eyebrow-pill eyebrow-pill-cyan">✨ @Model.Count ledger events</span>
    <a class="btn btn-primary" href="/transakcije/nova">Nova transakcija</a>
</div>

<div class="search-bar">
    <input type="text" id="searchInput" class="form-input" placeholder="Pretraga transakcija..." autocomplete="off" />
</div>

@if (!Model.Any())
{
    <p class="empty-state">Nema transakcija.</p>
}
else
{
    <div class="entity-grid" id="entityGrid">
        @foreach (var tx in Model)
        {
            <div class="entity-card-wrap">
                <a class="entity-card" href="/igraci/@tx.PlayerId">
                    <div class="card-header">
                        <span class="card-title" style="color:var(--violet-hi);">@tx.Player.FirstName @tx.Player.LastName</span>
                        @if (tx.Type == aspnet.Models.TransactionType.Deposit)
                        {
                            <span class="badge badge-available">Uplata</span>
                        }
                        else if (tx.Type == aspnet.Models.TransactionType.Win)
                        {
                            <span class="badge badge-available">Dobitak</span>
                        }
                        else if (tx.Type == aspnet.Models.TransactionType.Withdrawal)
                        {
                            <span class="badge badge-tx-danger">Isplata</span>
                        }
                        else
                        {
                            <span class="badge badge-tx-danger">Ulog</span>
                        }
                    </div>
                    <div class="card-meta">
                        <div>Iznos: <span class="mono">@tx.Amount.ToString("C")</span></div>
                        <div>Datum: <span class="mono">@tx.CreatedAt.ToString("dd MMM yyyy HH:mm")</span></div>
                    </div>
                </a>
            </div>
        }
    </div>
}

@section Scripts {
<script>
$(function () {
    var debounceTimer;
    var $grid = $('#entityGrid');

    function txBadge(type) {
        if (type === 'Deposit' || type === 0)   return '<span class="badge badge-available">Uplata</span>';
        if (type === 'Win'     || type === 3)   return '<span class="badge badge-available">Dobitak</span>';
        if (type === 'Withdrawal' || type === 1) return '<span class="badge badge-tx-danger">Isplata</span>';
        return '<span class="badge badge-tx-danger">Ulog</span>';
    }

    function renderTransactions(txs) {
        if (!txs || txs.length === 0) {
            $grid.html('<p class="empty-state">Nema rezultata.</p>');
            return;
        }
        var html = '';
        $.each(txs, function (i, t) {
            html += '<div class="entity-card-wrap">' +
                '<a class="entity-card" href="/igraci/' + (t.playerId || '') + '">' +
                '<div class="card-header"><span class="card-title" style="color:var(--violet-hi);">' + (t.playerName || '') + '</span>' +
                txBadge(t.type) + '</div>' +
                '<div class="card-meta">' +
                '<div>Iznos: <span class="mono">' + (t.amount || '') + '</span></div>' +
                '<div>Datum: <span class="mono">' + (t.createdAt || '') + '</span></div>' +
                '</div>' +
                '</a></div>';
        });
        $grid.html(html);
    }

    $('#searchInput').on('input', function () {
        clearTimeout(debounceTimer);
        var q = $(this).val().trim();
        if (!q) { location.reload(); return; }
        debounceTimer = setTimeout(function () {
            $.getJSON('/transakcije/pretraga', { q: q }, function (data) { renderTransactions(data); });
        }, 300);
    });
});
</script>
}
