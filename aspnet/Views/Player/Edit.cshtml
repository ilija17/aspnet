@* Edit form for a single Player. Includes client-side validation via _ValidationScriptsPartial. *@
@model aspnet.Models.Player
@{
    ViewData["Title"] = "Uredi igrača";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a asp-controller="Player" asp-action="Index">Players</a>
    <span class="breadcrumb-sep">›</span>
    <a asp-controller="Player" asp-action="Details" asp-route-id="@Model.Id">@Model.FirstName @Model.LastName</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Uredi</span>
</div>

<h1 class="page-title">Uredi igrača</h1>

<div class="edit-form-wrap">
    <form asp-action="Edit" method="post" novalidate>
        <input asp-for="Id" type="hidden" />

        <div class="form-field">
            <label asp-for="FirstName" class="form-label">Ime</label>
            <input asp-for="FirstName" class="form-input" />
            <span asp-validation-for="FirstName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="LastName" class="form-label">Prezime</label>
            <input asp-for="LastName" class="form-input" />
            <span asp-validation-for="LastName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="Email" class="form-label">E-mail</label>
            <input asp-for="Email" class="form-input" type="email" />
            <span asp-validation-for="Email" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="DateOfBirth" class="form-label">Datum rođenja</label>
            <input asp-for="DateOfBirth" class="form-input" type="date" />
            <span asp-validation-for="DateOfBirth" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="Balance" class="form-label">Saldo</label>
            <input asp-for="Balance" class="form-input" type="number" step="0.01" />
            <span asp-validation-for="Balance" class="form-validation"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-back" asp-controller="Player" asp-action="Details" asp-route-id="@Model.Id">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
