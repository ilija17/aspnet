@* Create form for a new Player. *@
@model aspnet.Models.Player
@{
    ViewData["Title"] = "Novi igrač";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/igraci">Players</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Novi igrač</span>
</div>

<h1 class="page-title">Novi igrač</h1>

<div class="edit-form-wrap">
    <form method="post" action="/igraci/novi" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label asp-for="FirstName" class="form-label">Ime</label>
            <input asp-for="FirstName" class="form-input" />
            <span asp-validation-for="FirstName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="LastName" class="form-label">Prezime</label>
            <input asp-for="LastName" class="form-input" />
            <span asp-validation-for="LastName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="Email" class="form-label">E-mail</label>
            <input asp-for="Email" class="form-input" type="email" />
            <span asp-validation-for="Email" class="form-validation"></span>
        </div>

        @await Html.PartialAsync("_DatePicker", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "DateOfBirth" },
            { "FieldLabel", "Datum rođenja" },
            { "Mode", "date" },
            { "CurrentValue", Model.DateOfBirth }
        })

        <div class="form-field">
            <label asp-for="Balance" class="form-label">Saldo</label>
            <input asp-for="Balance" class="form-input" type="number" step="0.01" min="0" />
            <span asp-validation-for="Balance" class="form-validation"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-back" href="/igraci">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('form').validate({ onfocusout: function (el) { this.element(el); } });
        });
    </script>
}
