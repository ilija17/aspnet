@* Shows a single table: table info with links to its casino and game, plus reservations made on it. *@
@model aspnet.Models.Table
@{
    ViewData["Title"] = "Table #" + Model.TableNumber;
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a asp-controller="Table" asp-action="Index">Tables</a>
    <span class="breadcrumb-sep">›</span>
    <span>Table #@Model.TableNumber</span>
</div>

<h1 class="page-title">Table #@Model.TableNumber</h1>

<div class="detail-grid">
    <div class="detail-section">
        <div class="detail-row">
            <span class="detail-label">Table Number</span>
            <span class="detail-value mono">#@Model.TableNumber</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Casino</span>
            <span class="detail-value">
                <a asp-controller="Casino" asp-action="Details" asp-route-id="@Model.CasinoId">@Model.Casino.Name</a>
            </span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Game</span>
            <span class="detail-value">
                <a asp-controller="Game" asp-action="Details" asp-route-id="@Model.GameId">@Model.Game.Name</a>
            </span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Min Bet</span>
            <span class="detail-value mono">@Model.MinBet</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Max Bet</span>
            <span class="detail-value mono">@Model.MaxBet</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Status</span>
            <span class="detail-value">
                @if (Model.IsAvailable)
                {
                    <span class="badge-available">Available</span>
                }
                else
                {
                    <span class="badge-unavailable">In Use</span>
                }
            </span>
        </div>
    </div>

    <div class="detail-section">
        <h2 class="section-title">Reservations</h2>
        @if (Model.Reservations.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>Reserved At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model.Reservations)
                    {
                        <tr>
                            <td>@reservation.Player.FirstName @reservation.Player.LastName</td>
                            <td class="mono">@reservation.ReservedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No reservations for this table.</p>
        }
    </div>
</div>

<div class="panel">
    <a class="btn btn-back" asp-controller="Table" asp-action="Index">Back to Tables</a>
</div>
