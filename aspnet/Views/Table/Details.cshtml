@* Shows a single table: table info with links to its casino and game, plus reservations made on it. *@
@model aspnet.Models.Table
@{
    ViewData["Title"] = "Table #" + Model.TableNumber;

    // Playable web game for this table's game type, or null when none exists.
    var playUrl = Model.Game.Type switch
    {
        aspnet.Models.GameType.Blackjack => "/kocka/index.html",
        aspnet.Models.GameType.Roulette  => "/rulet/index.html",
        _ => null
    };
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/stolovi">Tables</a>
    <span class="breadcrumb-sep">›</span>
    <span>Table #@Model.TableNumber</span>
</div>

<div class="index-action-bar" style="margin-top:0.5rem;">
    <h1 class="page-title" style="margin:0">Table #@Model.TableNumber</h1>
    @if (playUrl != null)
    {
        <a class="btn btn-primary" href="@playUrl" target="_blank" rel="noopener">Igraj @Model.Game.Name ▸</a>
    }
</div>

<div class="stat-bar" style="margin-top:1rem;">
    <div class="stat-pill"><span class="stat-label">Min ulog</span><span class="stat-value">@Model.MinBet</span></div>
    <div class="stat-pill"><span class="stat-label">Max ulog</span><span class="stat-value">@Model.MaxBet</span></div>
    <div class="stat-pill"><span class="stat-label">Rezervacije</span><span class="stat-value">@Model.Reservations.Count</span></div>
</div>

<div class="detail-grid">
    <div class="detail-section">
        <div class="detail-row">
            <span class="detail-label">Table Number</span>
            <span class="detail-value mono">#@Model.TableNumber</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Casino</span>
            <span class="detail-value">
                <a href="/kasina/@Model.CasinoId">@Model.Casino.Name</a>
            </span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Game</span>
            <span class="detail-value">
                <a href="/igre/@Model.GameId">@Model.Game.Name</a>
            </span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Min Bet</span>
            <span class="detail-value mono">@Model.MinBet</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Max Bet</span>
            <span class="detail-value mono">@Model.MaxBet</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Status</span>
            <span class="detail-value">
                @if (Model.IsAvailable)
                {
                    <span class="badge-available">Available</span>
                }
                else
                {
                    <span class="badge-unavailable">In Use</span>
                }
            </span>
        </div>
    </div>

    <div class="detail-section">
        <h2 class="section-title">Reservations</h2>
        @if (Model.Reservations.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>Reserved At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model.Reservations)
                    {
                        <tr>
                            <td>@reservation.Player.FirstName @reservation.Player.LastName</td>
                            <td class="mono">@reservation.ReservedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No reservations for this table.</p>
        }
    </div>
</div>

<div class="detail-actions">
    <a class="btn btn-back" href="/stolovi">Back to Tables</a>
    @if (playUrl != null)
    {
        <a class="btn btn-primary" href="@playUrl" target="_blank" rel="noopener">Igraj ▸</a>
    }
    <a class="btn btn-accent" href="/stolovi/@Model.Id/uredi">Uredi</a>
    <form method="post" action="/stolovi/@Model.Id/obrisi" class="d-inline" onsubmit="return confirm('Jesi li siguran da želiš obrisati ovaj stol?')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm" style="border-color:rgba(255,90,127,0.5);color:var(--danger)">Obriši</button>
    </form>
</div>

@section Scripts {}
