@* Create form for a new Table. Uses autocomplete for Casino and Game selection. *@
@model aspnet.Models.Table
@{
    ViewData["Title"] = "Novi stol";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/stolovi">Tables</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Novi stol</span>
</div>

<h1 class="page-title">Novi stol</h1>

<div class="edit-form-wrap">
    <form method="post" action="/stolovi/novi" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label asp-for="TableNumber" class="form-label">Broj stola</label>
            <input asp-for="TableNumber" class="form-input" type="number" min="1" />
            <span asp-validation-for="TableNumber" class="form-validation"></span>
        </div>

        <div class="form-check-wrap">
            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" id="IsAvailable" />
            <label asp-for="IsAvailable" class="form-check-label" for="IsAvailable">Slobodan</label>
        </div>

        <div class="form-field">
            <label asp-for="MinBet" class="form-label">Minimalni ulog</label>
            <input asp-for="MinBet" class="form-input" type="number" step="0.01" min="0" />
            <span asp-validation-for="MinBet" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="MaxBet" class="form-label">Maksimalni ulog</label>
            <input asp-for="MaxBet" class="form-input" type="number" step="0.01" min="0" />
            <span asp-validation-for="MaxBet" class="form-validation"></span>
        </div>

        @await Html.PartialAsync("_Autocomplete", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "CasinoId" },
            { "FieldLabel", "Casino" },
            { "EndpointUrl", "/kasina/autocomplete" },
            { "CurrentText", "" },
            { "CurrentId", "" }
        })

        @await Html.PartialAsync("_Autocomplete", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "GameId" },
            { "FieldLabel", "Igra" },
            { "EndpointUrl", "/igre/autocomplete" },
            { "CurrentText", "" },
            { "CurrentId", "" }
        })

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-back" href="/stolovi">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('form').validate({ onfocusout: function (el) { this.element(el); } });
        });
    </script>
}
