@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="access-denied panel">
    <div class="access-denied-code">500</div>
    <h1 class="page-title">Something hallucinated.</h1>
    <p class="access-denied-text" style="font-style:italic;">
        One of our agents confidently produced an answer that does not exist.
        We've escalated to a larger model.
    </p>
    <p class="access-denied-text">
        An error occurred while processing your request.
    </p>

    @if (Model.ShowRequestId)
    {
        <p class="access-denied-text">
            <strong>Request ID:</strong> <code class="mono">@Model.RequestId</code>
        </p>
    }

    <a class="btn btn-back" asp-controller="Home" asp-action="Index">Natrag na početnu</a>
</div>

<details style="max-width:520px;margin:1.5rem auto 0;color:var(--muted);font-size:0.8rem;">
    <summary style="cursor:pointer;">Development mode</summary>
    <p style="margin-top:0.6rem;">
        Swapping to the <strong>Development</strong> environment displays detailed error information.
        It should not be enabled for deployed applications — set
        <code class="mono">ASPNETCORE_ENVIRONMENT</code> to <code class="mono">Development</code> locally and restart the app.
    </p>
</details>
