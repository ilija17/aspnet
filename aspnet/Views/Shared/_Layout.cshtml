@* Shared layout — ✨ Performative UI theme: aurora mesh background, sparkle canvas,
   sticky Series-C banner, glass navbar with gradient brand + status dot, glass footer
   with compliance-vibes badges, and the AI concierge ChatFAB. *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CMS</title>
    <script type="importmap"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/casino.css" asp-append-version="true"/>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
<body>
<div class="aurora" aria-hidden="true">
    <div class="aurora-blob aurora-b1"></div>
    <div class="aurora-blob aurora-b2"></div>
    <div class="aurora-blob aurora-b3"></div>
</div>
<canvas id="sparkle-canvas" aria-hidden="true"></canvas>

<div class="sticky-banner" id="stickyBanner">
    <span class="banner-text">🎉 Our $420M Series C was oversubscribed 14x — <a href="/#waitlist">Join the waitlist</a> ✨</span>
    <button class="banner-dismiss" type="button" aria-label="Dismiss banner" title="Dismiss">×</button>
</div>

@{
    var currentPath = Context.Request.Path.Value ?? "";
    string NavClass(string prefix) =>
        currentPath.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
    var casinoClass = (currentPath.StartsWith("/kasina", StringComparison.OrdinalIgnoreCase) ||
                       currentPath.StartsWith("/stolovi", StringComparison.OrdinalIgnoreCase))
        ? "nav-link active" : "nav-link";
    var moreClass = (currentPath.StartsWith("/igraci", StringComparison.OrdinalIgnoreCase) ||
                     currentPath.StartsWith("/djelatnici", StringComparison.OrdinalIgnoreCase) ||
                     currentPath.StartsWith("/rezervacije", StringComparison.OrdinalIgnoreCase) ||
                     currentPath.StartsWith("/transakcije", StringComparison.OrdinalIgnoreCase) ||
                     currentPath.StartsWith("/vision", StringComparison.OrdinalIgnoreCase) ||
                     currentPath.StartsWith("/playground", StringComparison.OrdinalIgnoreCase))
        ? "nav-link active" : "nav-link";
}
<div class="app-shell">
  <nav class="top-bar">
    <div class="brand-group">
      <a class="brand" asp-controller="Home" asp-action="Index">CMS✨</a>
      <span class="status-dot-wrap" title="All systems agentic"><span class="status-dot"></span></span>
    </div>
    <button class="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <ul class="nav-links">
      <li class="nav-dropdown">
        <a class="@casinoClass nav-dropdown-trigger" href="/kasina" aria-haspopup="true">Casinos <span class="nav-caret" aria-hidden="true">▾</span></a>
        <ul class="nav-dropdown-menu" aria-label="Casinos">
          <li><a class="nav-dropdown-item" href="/kasina">All Casinos</a></li>
          <li><a class="nav-dropdown-item" href="/stolovi">Tables</a></li>
        </ul>
      </li>
      <li class="nav-dropdown">
        <a class="@NavClass("/igre") nav-dropdown-trigger" href="/igre" aria-haspopup="true">Games <span class="nav-caret" aria-hidden="true">▾</span></a>
        <ul class="nav-dropdown-menu" aria-label="Games">
          <li><a class="nav-dropdown-item" href="/igre">All games</a></li>
          <li><a class="nav-dropdown-item nav-dropdown-item-game" href="/kocka/index.html" target="_blank" rel="noopener">Blackjack (NERV) ↗</a></li>
          <li><a class="nav-dropdown-item nav-dropdown-item-game" href="/rulet/index.html" target="_blank" rel="noopener">Roulette ↗</a></li>
          <li><a class="nav-dropdown-item nav-dropdown-item-game" href="/threebody/index.html" target="_blank" rel="noopener">Three Body Problem ↗</a></li>
          <li><a class="nav-dropdown-item nav-dropdown-item-game" href="/slot/index.html" target="_blank" rel="noopener">Slots ↗</a></li>
        </ul>
      </li>
      <li class="nav-dropdown">
        <a class="@moreClass nav-dropdown-trigger" href="#" onclick="event.preventDefault()" aria-haspopup="true">More <span class="nav-caret" aria-hidden="true">▾</span></a>
        <ul class="nav-dropdown-menu" aria-label="More">
          <li><a class="nav-dropdown-item" href="/igraci">Players</a></li>
          <li><a class="nav-dropdown-item" href="/djelatnici">Employees</a></li>
          <li><a class="nav-dropdown-item" href="/rezervacije">Reservations</a></li>
          <li><a class="nav-dropdown-item" href="/transakcije">Transactions</a></li>
          <li><hr class="nav-dropdown-sep" /></li>
          <li><a class="nav-dropdown-item" href="/vision">The Vision</a></li>
          <li><a class="nav-dropdown-item" href="/playground">Playground</a></li>
        </ul>
      </li>
      <li class="nav-auth-item">
        <partial name="_LoginPartial" />
      </li>
    </ul>
    <div class="global-search-wrapper" role="search">
      <span class="global-search-icon" aria-hidden="true">🔍</span>
      <input
        type="search"
        class="global-search-input"
        placeholder="Pretraži sve…"
        autocomplete="off"
        aria-label="Globalna pretraga"
      />
      <div class="global-search-dropdown" role="listbox" aria-label="Rezultati pretrage"></div>
    </div>
  </nav>
  <main class="page-content">
    @RenderBody()
  </main>
  <footer class="site-footer">
    <span>Powered by frontier models ✨ &middot; Casino Management System &copy; 2026</span>
    <div class="footer-badges">
      <span class="compliance-badge">SOC-2 compliant vibes</span>
      <span class="compliance-badge">AGI-ready since 2026</span>
      <span class="compliance-badge">GDPR-curious</span>
      <span class="compliance-badge">∞ TAM certified</span>
      <span class="compliance-badge">0% hallucinations*</span>
    </div>
    <span style="font-size:0.66rem;opacity:0.7;">*as measured by our own eval suite</span>
  </footer>
</div>

@* AI concierge — canned responses only, no backend *@
<button id="chatFab" class="chat-fab" type="button" aria-label="AI concierge">✨</button>
<div id="chatPanel" class="chat-panel" role="dialog" aria-label="AI concierge chat">
  <div class="chat-header">
    <span class="status-dot"></span>
    <span class="gradient-text">Concierge-GPT</span>
    <span class="eyebrow-pill eyebrow-pill-cyan" style="margin-left:auto;">Frontier</span>
  </div>
  <div class="chat-body"></div>
  <div class="chat-input-row">
    <input id="chatInput" class="form-input" type="text" placeholder="Ask anything (it won't matter)…" autocomplete="off" />
    <button id="chatSend" class="chat-send" type="button">Send</button>
  </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
