@* Shared layout for all pages. Dark casino theme: top-bar navbar, app-shell container, footer.
   Links Google Fonts (Rajdhani, Inter, JetBrains Mono) and casino.css. *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CMS</title>
    <script type="importmap"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@700&family=Inter:wght@400;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/casino.css" asp-append-version="true"/>
</head>
<body>
<div class="app-shell">
  <nav class="top-bar">
    <a class="brand" asp-controller="Home" asp-action="Index">CMS</a>
    <ul class="nav-links">
      <li><a class="nav-link" href="/kasina">Casinos</a></li>
      <li><a class="nav-link" href="/igraci">Players</a></li>
      <li><a class="nav-link" href="/stolovi">Tables</a></li>
      <li><a class="nav-link" href="/igre">Games</a></li>
      <li><a class="nav-link" href="/djelatnici">Employees</a></li>
      <li><a class="nav-link" href="/rezervacije">Reservations</a></li>
      <li><a class="nav-link" href="/transakcije">Transactions</a></li>
      <li><a class="nav-link nav-link-game" href="/kocka/index.html" target="_blank" rel="noopener">Blackjack ↗</a></li>
    </ul>
  </nav>
  <main class="page-content">
    @RenderBody()
  </main>
  <footer class="site-footer">
    <span>Casino Management System &copy; 2026</span>
  </footer>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
