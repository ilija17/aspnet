@* Edit form for an existing Casino. *@
@model aspnet.Models.Casino
@{
    ViewData["Title"] = "Uredi casino";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/kasina">Casinos</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/kasina/@Model.Id">@Model.Name</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Uredi</span>
</div>

<h1 class="page-title">Uredi casino</h1>

<div class="edit-form-wrap">
    <form method="post" action="/kasina/@Model.Id/uredi" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="form-field">
            <label asp-for="Name" class="form-label">Naziv</label>
            <input asp-for="Name" class="form-input" />
            <span asp-validation-for="Name" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="Address" class="form-label">Adresa</label>
            <input asp-for="Address" class="form-input" />
            <span asp-validation-for="Address" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="LicenseNumber" class="form-label">Broj licence</label>
            <input asp-for="LicenseNumber" class="form-input" />
            <span asp-validation-for="LicenseNumber" class="form-validation"></span>
        </div>

        @await Html.PartialAsync("_DatePicker", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "FoundedDate" },
            { "FieldLabel", "Datum osnivanja" },
            { "Mode", "date" },
            { "CurrentValue", Model.FoundedDate }
        })

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-back" href="/kasina/@Model.Id">Odustani</a>
        </div>
    </form>
</div>

@* ── Dokumenti (privitci) — Dropzone upload + AJAX list ────── *@
<link rel="stylesheet" href="https://unpkg.com/dropzone@5/dist/min/dropzone.min.css" />

<div class="detail-section attachment-section">
    <h2 class="section-title">Dokumenti</h2>

    <form id="attachmentDz" class="dropzone" method="post" enctype="multipart/form-data"
          action="@Url.Action("UploadAttachment", "Casino", new { casinoId = Model.Id })">
        <div class="dz-message" data-dz-message>
            <span>Povuci dokument ovdje ili klikni za odabir</span>
        </div>
    </form>

    <div id="attachmentList" class="attachment-list"></div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('.edit-form-wrap form').validate({ onfocusout: function (el) { this.element(el); } });
        });
    </script>

    <script src="https://unpkg.com/dropzone@5/dist/min/dropzone.min.js"></script>
    <script>
        var attachmentListUrl = '@Url.Action("GetAttachments", "Casino", new { casinoId = Model.Id })';

        function loadAttachments() {
            $('#attachmentList').load(attachmentListUrl);
        }

        function deleteAttachment(id) {
            $.ajax({
                url: '@Url.Content("~/kasina/privitci/")' + id + '/obrisi',
                type: 'POST',
                success: loadAttachments
            });
        }

        Dropzone.options.attachmentDz = {
            paramName: "file",
            maxFilesize: 50, // MB
            success: function (file) {
                var dz = this;
                setTimeout(function () { dz.removeFile(file); }, 1200);
                loadAttachments();
            },
            error: function (file, message) {
                var text = (message && message.message) ? message.message : message;
                $(file.previewElement).addClass('dz-error').find('.dz-error-message span').text(text);
            }
        };

        $(loadAttachments);
    </script>
}
