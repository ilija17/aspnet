@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="panel" style="max-width:640px;margin:2rem auto;">
    <span class="eyebrow-pill">🔒 Privacy, performatively</span>
    <h1 class="page-title" style="margin-top:0.9rem;">@ViewData["Title"]</h1>
    <p style="color:var(--muted);line-height:1.6;">
        Your data is encrypted at rest, in transit, and in spirit.
        We only share it with our models, our investors, and anyone who asks nicely during diligence.
    </p>
    <p style="color:var(--muted);line-height:1.6;">
        Use this page to detail your site's privacy policy.
    </p>
</div>
