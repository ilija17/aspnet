@model List<aspnet.Models.Casino>
@{
    ViewData["Title"] = "Casino Floor";

    var totalCasinos = Model.Count;
    var totalTables = Model.Sum(c => c.Tables.Count);
    var availableTables = Model.Sum(c => c.Tables.Count(t => t.IsAvailable));
    var inUseTables = totalTables - availableTables;
}

<div class="page-header">
    <h1 class="page-title">Casino Floor</h1>
    <p style="color: var(--lime); margin-bottom: 1rem; font-size: 0.9rem; letter-spacing: 0.03em;">Live overview of all venues and table availability</p>
</div>

<div class="stat-bar">
    <div class="stat-pill">
        <span class="stat-label">Casinos</span>
        <span class="stat-value">@totalCasinos</span>
    </div>
    <div class="stat-pill">
        <span class="stat-label">Total Tables</span>
        <span class="stat-value">@totalTables</span>
    </div>
    <div class="stat-pill">
        <span class="stat-label">Available</span>
        <span class="stat-value">@availableTables</span>
    </div>
    <div class="stat-pill stat-pill-danger">
        <span class="stat-label">In Use</span>
        <span class="stat-value stat-in-use">@inUseTables</span>
    </div>
</div>

<div class="floor-grid">
    @foreach (var casino in Model)
    {
        <div class="floor-card">
            <div class="casino-name">
                <a asp-controller="Casino" asp-action="Details" asp-route-id="@casino.Id">@casino.Name</a>
            </div>
            <div class="casino-address">@casino.Address</div>
            <div class="table-chips">
                @foreach (var table in casino.Tables)
                {
                    <span class="table-chip @(table.IsAvailable ? "available" : "unavailable")">
                        T@(table.TableNumber) &middot; @table.Game.Name
                    </span>
                }
            </div>
            <a class="view-link" asp-controller="Casino" asp-action="Details" asp-route-id="@casino.Id">View details &rarr;</a>
        </div>
    }
</div>
