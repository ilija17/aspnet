@* Edit form for an existing Employee. Pre-fills autocomplete for Casino. *@
@model aspnet.Models.Employee
@{
    ViewData["Title"] = "Uredi djelatnika";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/djelatnici">Employees</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/djelatnici/@Model.Id">@Model.FirstName @Model.LastName</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Uredi</span>
</div>

<h1 class="page-title">Uredi djelatnika</h1>

<div class="edit-form-wrap">
    <form method="post" action="/djelatnici/@Model.Id/uredi" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="form-field">
            <label asp-for="FirstName" class="form-label">Ime</label>
            <input asp-for="FirstName" class="form-input" />
            <span asp-validation-for="FirstName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="LastName" class="form-label">Prezime</label>
            <input asp-for="LastName" class="form-input" />
            <span asp-validation-for="LastName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="Position" class="form-label">Pozicija</label>
            <input asp-for="Position" class="form-input" />
            <span asp-validation-for="Position" class="form-validation"></span>
        </div>

        @await Html.PartialAsync("_Autocomplete", (object)null, new ViewDataDictionary(ViewData) {
            { "FieldId", "CasinoId" },
            { "FieldLabel", "Casino" },
            { "EndpointUrl", "/kasina/autocomplete" },
            { "CurrentText", Model.Casino != null ? Model.Casino.Name : "" },
            { "CurrentId", Model.CasinoId.ToString() }
        })

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a class="btn btn-back" href="/djelatnici/@Model.Id">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('form').validate({ onfocusout: function (el) { this.element(el); } });
        });
    </script>
}
