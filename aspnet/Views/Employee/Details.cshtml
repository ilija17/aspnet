@* Shows a single employee: ID, name, position badge, and a link to their casino. *@
@model aspnet.Models.Employee
@{
    ViewData["Title"] = Model.FirstName + " " + Model.LastName;
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/djelatnici">Employees</a>
    <span class="breadcrumb-sep">›</span>
    <span>@Model.FirstName @Model.LastName</span>
</div>

<h1 class="page-title">@Model.FirstName @Model.LastName</h1>

<div class="detail-section">
    <div class="detail-row">
        <span class="detail-label">ID</span>
        <span class="detail-value mono">@Model.Id</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">First name</span>
        <span class="detail-value">@Model.FirstName</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Last name</span>
        <span class="detail-value">@Model.LastName</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Position</span>
        <span class="detail-value">
            <span class="badge-purple">@Model.Position</span>
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Casino</span>
        <span class="detail-value">
            <a href="/kasina/@Model.Casino.Id">@Model.Casino.Name</a>
        </span>
    </div>
</div>

<div class="detail-actions">
    <a class="btn btn-back" href="/djelatnici">Back to Employees</a>
    <a class="btn btn-accent" href="/djelatnici/@Model.Id/uredi">Uredi</a>
    <form method="post" action="/djelatnici/@Model.Id/obrisi" class="d-inline" onsubmit="return confirm('Jesi li siguran da želiš obrisati ovog djelatnika?')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm" style="border-color:rgba(255,90,127,0.5);color:var(--danger)">Obriši</button>
    </form>
</div>

@section Scripts {}
