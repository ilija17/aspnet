@model List<aspnet.Models.Employee>
@{
    ViewData["Title"] = "Employees";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Employees</span>
</div>

<div class="index-action-bar">
    <h1 class="page-title" style="margin:0">Employees</h1>
    <span class="eyebrow-pill eyebrow-pill-cyan">✨ @Model.Count humans in the loop</span>
    <a class="btn btn-primary" href="/djelatnici/novi">Dodaj novog djelatnika</a>
</div>

<div class="search-bar">
    <input type="text" id="searchInput" class="form-input" placeholder="Pretraga djelatnika..." autocomplete="off" />
</div>

<div class="entity-grid" id="entityGrid">
    @foreach (var employee in Model)
    {
        <div class="entity-card-wrap">
            <a class="entity-card" href="/djelatnici/@employee.Id">
                <div class="card-header">
                    <span class="card-title">@employee.FirstName @employee.LastName</span>
                    <span class="badge badge-purple">@employee.Position</span>
                </div>
                <div class="card-meta">
                    <div><span class="mono">#@employee.Id</span></div>
                    <div>Casino: <a href="/kasina/@employee.Casino.Id" style="color:var(--violet-hi);text-decoration:none;">@employee.Casino.Name</a></div>
                </div>
            </a>
            <div class="card-actions">
                <a class="btn btn-sm" href="/djelatnici/@employee.Id">Detalji</a>
                <a class="btn btn-sm btn-accent" href="/djelatnici/@employee.Id/uredi">Uredi</a>
                <form method="post" action="/djelatnici/@employee.Id/obrisi" class="d-inline" onsubmit="return confirm('Jesi li siguran da želiš obrisati ovog djelatnika?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm" style="border-color:rgba(255,90,127,0.5);color:var(--danger)">Obriši</button>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
$(function () {
    var debounceTimer;
    var $grid = $('#entityGrid');
    var antiForgeryToken = $('input[name="__RequestVerificationToken"]').first().val();

    function renderEmployees(employees) {
        if (!employees || employees.length === 0) {
            $grid.html('<p class="empty-state">Nema rezultata.</p>');
            return;
        }
        var html = '';
        $.each(employees, function (i, e) {
            html += '<div class="entity-card-wrap">' +
                '<a class="entity-card" href="/djelatnici/' + e.id + '">' +
                '<div class="card-header"><span class="card-title">' + e.firstName + ' ' + e.lastName + '</span>' +
                '<span class="badge badge-purple">' + (e.position || '') + '</span></div>' +
                '<div class="card-meta">' +
                '<div><span class="mono">#' + e.id + '</span></div>' +
                '<div>Casino: <a href="/kasina/' + (e.casinoId || '') + '" style="color:var(--violet-hi);text-decoration:none;">' + (e.casinoName || '') + '</a></div>' +
                '</div>' +
                '</a>' +
                '<div class="card-actions">' +
                '<a class="btn btn-sm" href="/djelatnici/' + e.id + '">Detalji</a> ' +
                '<a class="btn btn-sm btn-accent" href="/djelatnici/' + e.id + '/uredi">Uredi</a> ' +
                '<form method="post" action="/djelatnici/' + e.id + '/obrisi" class="d-inline" onsubmit="return confirm(\'Jesi li siguran?\')">' +
                '<input name="__RequestVerificationToken" type="hidden" value="' + antiForgeryToken + '" />' +
                '<button type="submit" class="btn btn-sm" style="border-color:rgba(255,90,127,0.5);color:var(--danger)">Obriši</button>' +
                '</form></div></div>';
        });
        $grid.html(html);
    }

    $('#searchInput').on('input', function () {
        clearTimeout(debounceTimer);
        var q = $(this).val().trim();
        if (!q) { location.reload(); return; }
        debounceTimer = setTimeout(function () {
            $.getJSON('/djelatnici/pretraga', { q: q }, function (data) { renderEmployees(data); });
        }, 300);
    });
});
</script>
}
