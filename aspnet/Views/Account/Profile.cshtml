@* "Moj profil" — editing personal data; email/username cannot be changed. *@
@model aspnet.Models.ProfileViewModel
@{
    ViewData["Title"] = "Moj profil";
}

<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Home</a>
    <span class="breadcrumb-sep">›</span>
    <span class="current">Moj profil</span>
</div>

<h1 class="page-title">Moj profil</h1>

<div class="edit-form-wrap auth-wrap">
    @if (TempData["ProfileSaved"] is not null)
    {
        <div class="form-success" role="status">Promjene su spremljene.</div>
    }

    <form asp-controller="Account" asp-action="Profile" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        @* Display-only: rendered without a name attribute so it is never posted nor validated. *@
        <div class="form-field">
            <label class="form-label" for="Email">E-mail</label>
            <input id="Email" type="email" class="form-input" value="@Model.Email" readonly />
            <span class="form-hint">E-mail adresa se ne može mijenjati.</span>
        </div>

        <div class="form-field">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-input" autocomplete="given-name" />
            <span asp-validation-for="FirstName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-input" autocomplete="family-name" />
            <span asp-validation-for="LastName" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="DateOfBirth" class="form-label"></label>
            <input asp-for="DateOfBirth" type="date" class="form-input" autocomplete="bday" />
            <span asp-validation-for="DateOfBirth" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="OIB" class="form-label"></label>
            <input asp-for="OIB" class="form-input" maxlength="11" inputmode="numeric" />
            <span asp-validation-for="OIB" class="form-validation"></span>
        </div>

        <div class="form-field">
            <label asp-for="JMBG" class="form-label"></label>
            <input asp-for="JMBG" class="form-input" maxlength="13" inputmode="numeric" />
            <span asp-validation-for="JMBG" class="form-validation"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi promjene</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
